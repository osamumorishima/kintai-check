# 担当インターン生の姓（カンマ区切り）
# 形式: バクラク上の名前:Slack上の名前（Slack名がローマ字の場合はコロンで区切る）
# 例: INTERN_NAMES=福田:Fukuta,上野:Ueno
INTERN_NAMES=福田:Fukuta,上野:Ueno

# Slack Bot Token（勤怠突合のSlack打刻データ取得に使用）
# customer-dashboard/.env に SLACK_BOT_TOKEN が設定済みの場合は不要
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
